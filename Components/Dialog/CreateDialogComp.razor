@using System.Diagnostics.CodeAnalysis
@using Altinn.ApiClients.Dialogporten.Features.V1
@using Digdir.BDB.Dialogporten.ServiceProvider.Components.Input
@using Digdir.BDB.Dialogporten.ServiceProvider.Components.Input.common
@using Digdir.BDB.Dialogporten.ServiceProvider.Extensions
@using Digdir.BDB.Dialogporten.ServiceProvider.Services

<div class="dialog-comp-container">
    <h3 class="comp-title">Create Dialog</h3>

    <EditForm Model="Value" OnValidSubmit="@(() => Submit())" FormName="CreateDialogTest" @ref="_form">
        <DataAnnotationsValidator/>
        <ValidationSummary class="validation-summary"/>

        <button type="button"  onclick="@Prefill">Prefill</button>
        <div class="form-section">
            <h4 class="section-title">Basic Information</h4>

            <div class="form-group">
                <label class="form-label">Id</label>
                <InputGuid @bind-Value="@Value.Id"></InputGuid>
                <ValidationMessage For="@(() => Value.Id)"/>
            </div>

            <div class="form-group">
                <label class="form-label">Idempotent Key</label>
                <InputText class="form-input" @bind-Value="@Value.IdempotentKey"></InputText>
                <ValidationMessage For="@(() => Value.IdempotentKey)"/>
            </div>

            <div class="form-group">
                <label class="form-label">Service Resource</label>
                <InputSelect class="form-select" @bind-Value="@Value.ServiceResource">
                    <option value="" disabled selected>Select your option</option>
                    @foreach (var status in ResourceRegistryClient.Resources)
                    {
                        <option value=@("urn:altinn:resource:" + status.Identifier)>@status.Identifier</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Value.ServiceResource)"/>
            </div>

            <div class="form-group">
                <label class="form-label">Party</label>
                <InputParty @bind-Value="Value.Party"></InputParty>
                <ValidationMessage For="@(() => Value.Party)"/>
            </div>

            <div class="form-group">
                <label class="form-label">Progress</label>
                <InputNumber class="form-input" @bind-Value="@Value.Progress"></InputNumber>
                <ValidationMessage For="@(() => Value.Progress)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="extendedStatus">Extended Status</label>
                <InputText class="form-input" id="extendedStatus" @bind-Value="@Value.ExtendedStatus"></InputText>
                <ValidationMessage For="@(() => Value.ExtendedStatus)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="externalReference">External Reference</label>
                <InputText class="form-input" id="externalReference" @bind-Value="@Value.ExternalReference"></InputText>
                <ValidationMessage For="@(() => Value.ExternalReference)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="process">Process</label>
                <InputText class="form-input" id="process" @bind-Value="@Value.Process"></InputText>
                <ValidationMessage For="@(() => Value.Process)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="precedingProcess">Preceding Process</label>
                <InputText class="form-input" id="precedingProcess" @bind-Value="@Value.PrecedingProcess"></InputText>
                <ValidationMessage For="@(() => Value.PrecedingProcess)"/>
            </div>

            <div class="form-group form-group--checkbox">
                <label class="form-label">Api Only</label>
                <InputCheckbox class="form-checkbox" @bind-Value="Value.IsApiOnly"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="status">Status</label>
                <InputSelect class="form-select" id="status" @bind-Value="@Value.Status">
                    @foreach (var status in Enum.GetValues<DialogsEntities_DialogStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Value.Status)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="systemLabel">System Label</label>
                <InputSelect class="form-select" id="systemLabel" @bind-Value="@Value.SystemLabel">
                    @foreach (var label in Enum.GetValues<DialogEndUserContextsEntities_SystemLabel>())
                    {
                        <option value="@label">@label</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Value.SystemLabel)"/>
            </div>
        </div>

        <div class="form-section">
            <h4 class="section-title">Dates & Times</h4>

            <div class="form-group">
                <label class="form-label" for="visibleFrom">Visible From</label>
                <DateInputWrapper id="visibleFrom" @bind-Value="@Value.VisibleFrom"/>
                <ValidationMessage For="@(() => Value.VisibleFrom)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="dueAt">Due At</label>
                <DateInputWrapper id="dueAt" @bind-Value="@Value.DueAt"/>
                <ValidationMessage For="@(() => Value.DueAt)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="expiresAt">Expires At</label>
                <DateInputWrapper id="expiresAt" @bind-Value="@Value.ExpiresAt"></DateInputWrapper>
                <ValidationMessage For="@(() => Value.ExpiresAt)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="createdAt">Created At</label>
                <DateInputWrapper id="createdAt" @bind-Value="@Value.CreatedAt"></DateInputWrapper>
                <ValidationMessage For="@(() => Value.CreatedAt)"/>
            </div>

            <div class="form-group">
                <label class="form-label" for="updatedAt">Updated At</label>
                <DateInputWrapper id="updatedAt" @bind-Value="@Value.UpdatedAt"></DateInputWrapper>
                <ValidationMessage For="@(() => Value.UpdatedAt)"/>
            </div>
        </div>

        <div class="form-section">
            <h4 class="section-title">Content</h4>
            <div class="form-group">
                <InputContent AdditionalAttributes="@_req" @bind-Value="@Value.Content"/>
            </div>
        </div>

        <fieldset class="fieldset">
            <legend class="fieldset-legend">Search Tags</legend>
            <div class="item-list">
                @foreach (var tag in Value.SearchTags)
                {
                    <div class="item-card">
                        <div class="item-content">
                            <div class="form-group">
                                <InputText class="form-input" @bind-Value="tag.Value"></InputText>
                                <ValidationMessage For="@(() => tag.Value)"></ValidationMessage>
                            </div>
                        </div>
                        <div class="item-actions">
                            <button type="button"  @onclick="() => Value.SearchTags.Remove(tag)">
                                Remove
                            </button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" 
                    @onclick="() => Value.SearchTags.Add(new V1ServiceOwnerDialogsCommandsCreate_Tag())">
                Add Search Tag
            </button>
        </fieldset>

        <fieldset class="fieldset">
            <legend class="fieldset-legend">Attachments</legend>
            <div class="item-list">
                @foreach (var attachment in Value.Attachments)
                {
                    <div class="item-card">
                        <div class="item-content">
                            <div class="form-group">
                                <label class="form-label">Id</label>
                                <InputGuid @bind-Value="@attachment.Id"/>
                                <ValidationMessage For="@(() => attachment.Id)"/>
                            </div>
                            <div class="form-group">
                                <label class="form-label">URLs</label>
                                <InputAttachmentUrl @bind-Value="@attachment.Urls"/>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Display Name</label>
                                <InputLocalization @bind-Value="attachment.DisplayName"/>
                            </div>
                        </div>
                        <div class="item-actions">
                            <button type="button"  @onclick="() => RemoveAttachment(attachment)">
                                Remove
                            </button>
                        </div>
                    </div>
                }
            </div>
            <button type="button"  @onclick="AddAttachment">Add Attachment</button>
        </fieldset>

        <div class="form-section">
            <h4 class="section-title">Transmissions</h4>
            <InputTransmission @bind-Value="@Value.Transmissions"/>
        </div>

        <fieldset class="fieldset">
            <legend class="fieldset-legend">GUI Actions</legend>
            <InputGuiActions @bind-Value="Value.GuiActions"/>
        </fieldset>

        <fieldset class="fieldset">
            <legend class="fieldset-legend">API Actions</legend>
            <InputApiAction @bind-Value="Value.ApiActions"/>
        </fieldset>

        <fieldset class="fieldset">
            <legend class="fieldset-legend">Activities</legend>
            <InputActivites @bind-Value="Value.Activities"/>
        </fieldset>

        <fieldset class="fieldset">
            <legend class="fieldset-legend">Service Owner Labels</legend>
            <div class="item-list">
                @foreach (var serviceOwnerLabel in Value.ServiceOwnerContext.ServiceOwnerLabels)
                {
                    <div class="item-card">
                        <div class="item-content">
                            <div class="form-group">
                                <InputText class="form-input" @bind-Value="serviceOwnerLabel.Value"></InputText>
                                <ValidationMessage For="@(() => serviceOwnerLabel.Value)"></ValidationMessage>
                            </div>
                        </div>
                        <div class="item-actions">
                            <button type="button" 
                                    @onclick="() => Value.ServiceOwnerContext.ServiceOwnerLabels.Remove(serviceOwnerLabel)">
                                Remove
                            </button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" 
                    onclick="@(() => Value.ServiceOwnerContext.ServiceOwnerLabels.Add(new V1ServiceOwnerDialogsCommandsCreate_ServiceOwnerLabel()))">
                Add Service Owner Label
            </button>
        </fieldset>

        <button type="submit" >Submit</button>
    </EditForm>
</div>



@code {
    [Parameter]
    public Action? Prefill { get; set; }

    [Parameter]
    public required Action Submit { get; set; }


    [Parameter]
    public required V1ServiceOwnerDialogsCommandsCreate_Dialog Value { get; set; }

    private EditForm _form = null!;

    private ValidationMessageStore _messageStore = null!;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _messageStore = new ValidationMessageStore(_form.EditContext ?? throw new NullReferenceException());
            _form.EditContext.OnValidationRequested += ValidateForm;
        }
    }
    

    private void ValidateForm(object? sender, ValidationRequestedEventArgs e)
    {
        var context = (EditContext)sender!;

        _messageStore.Clear();

        ValidateContentValue(Value.Content.Title, nameof(Value.Content.Title));
        ValidateContentValue(Value.Content.NonSensitiveTitle, nameof(Value.Content.NonSensitiveTitle));

        ValidateContentValue(Value.Content.Summary, nameof(Value.Content.Summary));
        ValidateContentValue(Value.Content.NonSensitiveSummary, nameof(Value.Content.NonSensitiveSummary));

        ValidateContentValue(Value.Content.SenderName, nameof(Value.Content.SenderName));

        ValidateContentValue(Value.Content.AdditionalInfo, nameof(Value.Content.AdditionalInfo));

        ValidateContentValue(Value.Content.ExtendedStatus, nameof(Value.Content.ExtendedStatus));

        ValidateContentValue(Value.Content.MainContentReference, nameof(Value.Content.MainContentReference));

        context.NotifyValidationStateChanged();

    }

    private void ValidateContentValue(V1CommonContent_ContentValue? content, string name)
    {
        if (content is null) return;

        if ((content.Value == null || !content.Value.Any()) && !string.IsNullOrEmpty(content.MediaType))
        {
            var fieldId = new FieldIdentifier(Value, $"Content.{name}.Value");
            _messageStore.Add(fieldId, $"{name} requires at least one localization");
            return;
        }

        if (content.Value != null && content.Value.Any() && string.IsNullOrEmpty(content.MediaType))
        {
            var fieldId = new FieldIdentifier(Value, $"Content.{name}.Value");
            _messageStore.Add(fieldId, $"{name} requires mediaType if you have any localization");
        }

    }
    private readonly Dictionary<string, object?> _req = new()
    {
        { "required", true }
    };


    [SuppressMessage("ReSharper", "NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract")]
    protected override void OnInitialized()
    {
        base.OnInitialized();
        var deleteButton = new V1ServiceOwnerDialogsCommandsCreate_GuiAction();
        deleteButton.Prefill(GuiActionPrefill.DeleteButton);
        Value.ServiceOwnerContext ??= new V1ServiceOwnerDialogsCommandsCreate_DialogServiceOwnerContext
        {
            ServiceOwnerLabels = []
        };


        Value.Attachments ??= [];
        Value.SearchTags ??=
        [
            new V1ServiceOwnerDialogsCommandsCreate_Tag
            {
                Value = "SOv0.1"
            }
        ];
        Value.Transmissions ??= [];
        Value.GuiActions ??= [deleteButton];
        Value.ApiActions ??= [];
        Value.Activities ??= [];
    }


    private void AddAttachment()
    {
        Value.Attachments.Add(new V1ServiceOwnerDialogsCommandsCreate_Attachment
        {
            Id = null,
            DisplayName = [],
            Urls = []
        });
    }

    private void RemoveAttachment(V1ServiceOwnerDialogsCommandsCreate_Attachment attachment)
    {
        Value.Attachments.Remove(attachment);
    }
}

